{
  "expo": {
    "name": "medlens",
    "slug": "medlens",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "medlens",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "usesAppleSignIn": true,
      "supportsTablet": true,
      "bundleIdentifier": "com.timothy.medlens",
      "infoPlist": {
        "NSCalendarsUsageDescription": "MedLens uses your calendar to schedule medication reminders so you never miss a dose.",
        "NSRemindersUsageDescription": "MedLens creates reminders to alert you when it's time to take your medications.",
        "NSCalendarsFullAccessUsageDescription": "MedLens needs full calendar access to create and manage your medication schedule events."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.timothy.medlens",
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FC6631",
          "dark": {
            "backgroundColor": "#FC6631"
          }
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "MedLens uses your calendar to schedule medication reminders.",
          "remindersPermission": "MedLens creates reminders for your medications."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF6B35",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "MedLens Reminders",
          "iosDisplayInForeground": true
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d4ba580b-827a-4ed1-b73a-2228b5aa46ef"
      }
    }
  }
}
